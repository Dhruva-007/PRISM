# ============================================================
# PRISM Frontend .gitignore
# ============================================================

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js build output ─────────────────────────────────────
.next/
out/

# ── Production build ─────────────────────────────────────────
build/
dist/

# ── Environment and secrets ──────────────────────────────────
# .env.local contains Firebase config and API keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
.env.staging
!.env.example

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# ── Linting and formatting ───────────────────────────────────
.eslintcache

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# ── IDE ──────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ── Vercel (not used but excluded if accidentally created) ────
.vercel

# ── Storybook (not used) ─────────────────────────────────────
storybook-static/

# ── Temporary ────────────────────────────────────────────────
*.tmp
*.temp
.cache/
tmp/

# ── MapLibre GL (large generated files) ──────────────────────
# These come from npm — never commit them
public/maplibre/

# ── Docker ───────────────────────────────────────────────────
.docker/

# ── Package manager locks ────────────────────────────────────
pnpm-lock.yaml
bun.lockb

# Cloud Build config — manage secrets via GCP Console substitutions
cloudbuild.yaml