# ============================================================
# PRISM Root .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
*.whl

# ── Virtual environments ─────────────────────────────────────
backend/venv/
backend/.venv/
backend/env/
backend/ENV/

# ── Node ─────────────────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/

# ── Environment files (ALL environments) ─────────────────────
backend/.env
frontend/.env.local
frontend/.env.production
frontend/.env.staging

# Keep .env.example files — they are documentation
!backend/.env.example
!frontend/.env.example

# ── Firebase service account key ─────────────────────────────
backend/firebase-service-account.json
*firebase-service-account*.json
*service-account*.json
*serviceAccount*.json

# ── Google Cloud credentials ─────────────────────────────────
application_default_credentials.json
gcloud-credentials.json

# ── IDE and editor files ─────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.vs/

# ── OS generated files ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing and coverage ─────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
coverage.xml
*.cover
.nyc_output/
coverage/

# ── Build artifacts ──────────────────────────────────────────
*.tsbuildinfo
frontend/next-env.d.ts

# ── Temporary files ──────────────────────────────────────────
*.tmp
*.temp
.cache/
tmp/
temp/

# ── Docker ───────────────────────────────────────────────────
.docker/

# ── Deployment artifacts ─────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup

# ── Firestore emulator data ──────────────────────────────────
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log